# OneLink Brain environment — copy to /etc/onelink/brain.env on the Pi
#
# Public broker (default): ESP32 and Pi share broker.emqx.io so the Pi's
# changing hotspot IP never breaks card taps.
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_TOPIC=onelink/hardware/tap
MQTT_TOPIC_HEARTBEAT=onelink/hardware/heartbeat

# Lab/local Mosquitto instead:
# MQTT_BROKER=127.0.0.1

KIOSK_WS_HOST=0.0.0.0
KIOSK_WS_PORT=8765
DEFAULT_TERMINAL=main_kiosk
AUTO_PAY=0
