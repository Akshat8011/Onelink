NODE_ENV=development
PORT=10000

# MongoDB Atlas (replace with your own URI — never commit real credentials)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/onelink?retryWrites=true&w=majority

# JWT (generate a long random secret for production)
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# MQTT
MQTT_BROKER_URL=mqtt://broker.emqx.io
MQTT_PORT=1883
MQTT_CLIENT_ID=onelink-cloud-backend-dev

# Comma-separated origins in production, e.g. https://onelink-wine-psi.vercel.app
SOCKET_CORS_ORIGIN=*
