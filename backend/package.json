{
  "name": "onelink-backend",
  "version": "1.0.0",
  "description": "OneLink Super App - Cloud Backend with MQTT IoT Gateway",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "npm run build && node dist/seed.js",
    "test": "jest --passWithNoTests",
    "test:mqtt": "ts-node src/__tests__/mqtt.test.ts",
    "verify:logic": "npm run build && node scripts/verify_phase23_logic.cjs",
    "verify:db": "npm run build && node scripts/verify_phase2_db.cjs",
    "verify": "npm run verify:logic && node scripts/verify_phase2_db.cjs"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "mqtt": "^5.3.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "mongodb-memory-server-core": "^11.2.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
